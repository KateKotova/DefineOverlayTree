<UserControl x:Class="DefineOverlayTree.DefineOverlayPanel.GraphicalOverlayView.OverlayWithCirclesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity"
             xmlns:graphicalOverlayView="clr-namespace:DefineOverlayTree.DefineOverlayPanel.GraphicalOverlayView"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance graphicalOverlayView:OverlayWithCirclesViewModel}"
             d:DesignHeight="300" d:DesignWidth="300">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/DefineOverlayTree;component/Icons/PathIcons.xaml" />
                <ResourceDictionary Source="pack://application:,,,/DefineOverlayTree;component/Styles/Brushes.xaml" />
                <ResourceDictionary Source="pack://application:,,,/DefineOverlayTree;component/Styles/ButtonStyles.xaml" />
                <ResourceDictionary Source="pack://application:,,,/DefineOverlayTree;component/Styles/TextBlockStyles.xaml" />
                <ResourceDictionary Source="pack://application:,,,/DefineOverlayTree;component/Styles/TextBoxStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

            <SolidColorBrush x:Key="ActiveCircleBrush" Color="{StaticResource Signal2RegularColor}" />
            <SolidColorBrush x:Key="InvalidBrush" Color="{StaticResource Signal1RegularColor}" />

            <Style x:Key="CircleStyle" TargetType="Ellipse">
                <Setter Property="Canvas.Left" Value="{Binding Source={x:Static graphicalOverlayView:GraphicalOverlaySizes.CircleX}}" />
                <Setter Property="Width" Value="{Binding Source={x:Static graphicalOverlayView:GraphicalOverlaySizes.CircleDiameter}}" />
                <Setter Property="Height" Value="{Binding Source={x:Static graphicalOverlayView:GraphicalOverlaySizes.CircleDiameter}}" />
                <Setter Property="Fill" Value="{StaticResource BlueRegularBrush}"/>
                <Setter Property="IsEnabled" Value="{Binding IsEnabled}"/>
                <Style.Triggers>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding IsInEditMode}" Value="false" />
                            <Condition Binding="{Binding HasNoSelectedLayers}" Value="false" />
                            <Condition Binding="{Binding Overlay.OverlayModel}" Value="{x:Null}" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Fill" Value="{StaticResource InvalidBrush}"/>
                    </MultiDataTrigger>
                    <MultiTrigger>
                        <MultiTrigger.Conditions>
                            <Condition Property="IsMouseOver" Value="True"/>
                            <Condition Property="IsEnabled" Value="True"/>
                        </MultiTrigger.Conditions>
                        <MultiTrigger.Setters>
                            <Setter Property="Fill" Value="{StaticResource ActiveCircleBrush}"/>
                        </MultiTrigger.Setters>
                    </MultiTrigger>
                    <DataTrigger Binding="{Binding IsInEditMode}" Value="True">
                        <Setter Property="Fill" Value="{StaticResource Signal2RegularBrush}"/>
                        <DataTrigger.EnterActions>
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever" TargetProperty="Opacity">
                                    <DoubleAnimation From="0.4" To="1" Duration="0:0:0.75" AutoReverse="True"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </DataTrigger.EnterActions>
                        <DataTrigger.ExitActions>
                            <BeginStoryboard>
                                <Storyboard TargetProperty="Opacity">
                                    <DoubleAnimation To="1" />
                                </Storyboard>
                            </BeginStoryboard>
                        </DataTrigger.ExitActions>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="ArrowStyle" TargetType="Path">
                <Setter Property="Canvas.Top" Value="{Binding ArrowPointY}" />
                <Setter Property="Canvas.Left" Value="{Binding Source={x:Static graphicalOverlayView:GraphicalOverlaySizes.ArrowPointX}}" />
                <Setter Property="Fill" Value="{StaticResource BlackColorBrush}" />
                <Setter Property="Width" Value="{Binding Source={x:Static graphicalOverlayView:GraphicalOverlaySizes.ArrowPointWidth}}" />
                <Setter Property="Height" Value="{Binding Source={x:Static graphicalOverlayView:GraphicalOverlaySizes.ArrowPointHeight}}" />
                <Setter Property="Stroke" Value="{StaticResource BlackColorBrush}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="Data" Value="{Binding Source={StaticResource ArrowPointBottomString}}" />
                <Setter Property="Stretch" Value="Fill" />
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding IsFilled}" Value="True" />
                            <Condition Binding="{Binding HasReversedLayers}" Value="False" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Visibility" Value="Visible" />
                    </MultiDataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="LineStyle" TargetType="Line">
                <Setter Property="Canvas.Top" Value="{Binding ArrowLineStartY}" />
                <Setter Property="Canvas.Left" Value="{Binding Source={x:Static graphicalOverlayView:GraphicalOverlaySizes.ArrowLineX}}" />
                <Setter Property="X1" Value="0" />
                <Setter Property="Y1" Value="0" />
                <Setter Property="X2" Value="0" />
                <Setter Property="Y2" Value="1" />
                <Setter Property="Width" Value="{Binding Source={x:Static graphicalOverlayView:GraphicalOverlaySizes.ArrowLineWidth}}" />
                <Setter Property="Height" Value="{Binding ArrowLineLength}" />
                <Setter Property="Stroke" Value="{StaticResource BlackColorBrush}" />
                <Setter Property="StrokeThickness" Value="{Binding Source={x:Static graphicalOverlayView:GraphicalOverlaySizes.ArrowLineWidth}}" />
                <Setter Property="StrokeStartLineCap" Value="Square" />
                <Setter Property="StrokeEndLineCap" Value="Square" />
                <Setter Property="Stretch" Value="Fill" />
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding IsFilled}" Value="True" />
                            <Condition Binding="{Binding HasReversedLayers}" Value="False" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Visibility" Value="Visible" />
                    </MultiDataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Canvas Width="{Binding Source={x:Static graphicalOverlayView:GraphicalOverlaySizes.OverlayColumnWidth}}">
        <Ellipse Canvas.Top="{Binding Circle0Y}"
                 Style="{StaticResource CircleStyle}"
                 Visibility="{Binding Circle0IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="MouseDown">
                    <i:InvokeCommandAction Command="{Binding CircleMouseDownCommand}" CommandParameter="0" />
                </i:EventTrigger>
            </i:Interaction.Triggers>
        </Ellipse>

        <Ellipse Canvas.Top="{Binding Circle1Y}"
                 Style="{StaticResource CircleStyle}"
                 Visibility="{Binding Circle1IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="MouseDown">
                    <i:InvokeCommandAction Command="{Binding CircleMouseDownCommand}" CommandParameter="1" />
                </i:EventTrigger>
            </i:Interaction.Triggers>
        </Ellipse>

        <Path Style="{StaticResource ArrowStyle}"/>
        <Line Style="{StaticResource LineStyle}"/>
    </Canvas>
</UserControl>
